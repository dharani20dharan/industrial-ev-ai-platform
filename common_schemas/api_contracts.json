{
  "info": {
    "title": "Industrial EV AI Platform - API Contracts & Schemas",
    "version": "1.0.0",
    "description": "Standardized request and response payloads, event schemas, and WebSocket updates used by the backend developer to build and integrate services.",
    "last_updated": "2026-07-15T14:20:00Z"
  },
  "streaming_event_envelope": {
    "description": "Standardized event envelope wrapping all platform domain payloads transferred over Kafka/MQTT pipelines.",
    "schema": {
      "event_id": {
        "type": "UUID",
        "description": "Unique identifier for this specific event instance"
      },
      "event_type": {
        "type": "string",
        "description": "The type of event (e.g., 'telemetry.raw', 'battery.alert', 'predictions')"
      },
      "timestamp": {
        "type": "string",
        "format": "date-time",
        "description": "UTC timestamp of event generation"
      },
      "source": {
        "type": "string",
        "description": "Originating service or simulator node name"
      },
      "vehicle_id": {
        "type": "string",
        "description": "Unique immutable ID of the industrial vehicle"
      },
      "fleet_id": {
        "type": "string",
        "description": "Identifier for the tracking fleet operational partition"
      },
      "correlation_id": {
        "type": "UUID",
        "description": "Tracing ID sustained across asynchronous boundaries"
      },
      "payload": {
        "type": "object",
        "description": "The concrete domain data model matching the event type"
      }
    },
    "example": {
      "event_id": "9b1deb4d-3b7d-4bad-9bdd-2b0d7b3dcb6d",
      "event_type": "telemetry.processed",
      "timestamp": "2026-07-15T14:15:00Z",
      "source": "telemetry.processing.node-1",
      "vehicle_id": "EV-HD-001",
      "fleet_id": "FLEET-SOUTH-42",
      "correlation_id": "c1a9c394-ff00-4b0d-85ba-197cc4fbe256",
      "payload": {
        "speed_kph": 58.4,
        "odometer_km": 12450.2,
        "motor_temperature_c": 64.2,
        "torque_nm": 210.5,
        "inverter_efficiency": 0.94
      }
    }
  },
  "streaming_payloads": {
    "telemetry": {
      "description": "Core kinematic data from the vehicle's engine and operational control units.",
      "fields": {
        "speed_kph": { "type": "float", "range": [0, 200], "default": 0.0 },
        "odometer_km": { "type": "float", "min": 0, "default": 0.0 },
        "motor_temperature_c": { "type": "float", "range": [-40, 150], "default": 65.0 },
        "torque_nm": { "type": "float", "default": 210.5 },
        "inverter_efficiency": { "type": "float", "range": [0, 1], "default": 0.94 }
      }
    },
    "battery": {
      "description": "Real-time electro-chemical battery state statistics.",
      "fields": {
        "state_of_charge_pct": { "type": "float", "range": [0, 100] },
        "state_of_health_pct": { "type": "float", "range": [0, 100] },
        "voltage": { "type": "float", "range": [0, 1000] },
        "current_amps": { "type": "float" },
        "cell_temperature_max_c": { "type": "float", "range": [-40, 100] },
        "internal_resistance_ohm": { "type": "float", "min": 0 }
      }
    },
    "location": {
      "description": "High-precision positional telemetry coordinate data.",
      "fields": {
        "latitude": { "type": "float", "range": [-90, 90], "default": 39.7392 },
        "longitude": { "type": "float", "range": [-180, 180], "default": -104.9903 },
        "altitude_m": { "type": "float", "range": [-500, 9000], "default": 1609.0 },
        "heading_deg": { "type": "float", "range": [0, 360], "default": 0.0 },
        "gps_fix_quality": { "type": "int", "description": "0=Invalid, 1=GPS, 2=DGPS", "default": 1 }
      }
    },
    "charging": {
      "description": "State management metrics during an active battery charging session.",
      "fields": {
        "charger_id": { "type": "string", "default": "CHG-STATION-MOCK" },
        "charging_rate_kw": { "type": "float", "min": 0, "default": 0.0 },
        "time_to_full_mins": { "type": "float", "min": 0, "default": 0.0 },
        "connector_type": { "type": "string", "description": "CCS2, Megawatt, etc.", "default": "CCS2" }
      }
    },
    "status": {
      "description": "High-level operating mode state flags.",
      "fields": {
        "operational_status": { "type": "string", "description": "READY, OPERATIONAL, FAULT, OFFLINE", "default": "OPERATIONAL" },
        "active_error_codes": { "type": "array of strings", "default": [] },
        "driver_id": { "type": "string", "nullable": true, "default": "SYSTEM_AUTO" }
      }
    },
    "alerts": {
      "description": "Immediate hardware or safety critical notifications.",
      "fields": {
        "alert_code": { "type": "string", "default": "CLR_00" },
        "severity": { "type": "string", "description": "INFO, WARNING, CRITICAL", "default": "INFO" },
        "component": { "type": "string", "description": "BATTERY, MOTOR, BRAKES, POWERTRAIN", "default": "SYSTEM" },
        "description": { "type": "string", "default": "Healthy baseline initialization status." }
      }
    },
    "heartbeat": {
      "description": "Lightweight diagnostics asserting infrastructure network health.",
      "fields": {
        "uptime_seconds": { "type": "int", "min": 0, "default": 0 },
        "firmware_version": { "type": "string", "default": "v1.0.0-mock" },
        "signal_strength_dbm": { "type": "int", "max": 0, "default": -50 }
      }
    }
  },
